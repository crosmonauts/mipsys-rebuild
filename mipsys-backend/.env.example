# === BACKEND .ENV ===
# Untuk development lokal, copy file ini ke .env dan sesuaikan.
# Untuk Railway: cukup set DATABASE_URL, CORS_ORIGINS, JWT_SECRET, JWT_EXPIRES_IN
# Railway PostgreSQL plugin akan auto-inject DATABASE_URL

# Database (PostgreSQL via Docker)
DB_HOST=127.0.0.1
DB_USER=mipsys
DB_PASS=mipsys
DB_NAME=db_mipsys
DB_PORT=5433
DB_CONNECTION_LIMIT=10
DATABASE_URL=postgresql://mipsys:mipsys@127.0.0.1:5433/db_mipsys

# CORS — domain frontend yang diizinkan akses API
CORS_ORIGINS=http://localhost:3000

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=mipsys-dev-secret
JWT_EXPIRES_IN=1d
